{
  "manifest_version": 3,
  "name": "Email Threat Detector",
  "version": "1.0",
  "description": "Scans open emails for phishing and threats using Gemini AI.",

  "permissions": [
    "activeTab",
    "scripting"
  ],

  "host_permissions": [
    "https://mail.google.com/*"
  ],

  "background": {
    "service_worker": "background/service_worker.js",
    "type": "module"
  },

  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "128": "icons/shield.png"
    }
  },

  "content_scripts": [
    {
      "matches": [
        "https://mail.google.com/*"
      ],
      "js": ["content/email_extractor.js"],
      "run_at": "document_idle"
    }
  ],

  "icons": {
    "128": "icons/shield.png"
  }
}
